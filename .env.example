MARP_ENV=production
MARP_API_PREFIX=/api
MARP_DATABASE_URL=postgresql+asyncpg://marp:marp@postgres:5432/marp
MARP_REDIS_URL=redis://redis:6379/0
MARP_DIRECTOR_VISIBILITY_DELAY_SECONDS=300
MARP_SCHEDULER_POLL_SECONDS=15
MARP_WORLD_DEFAULT_SPEED_MULTIPLIER=60
MARP_DB_AUTO_CREATE_SCHEMA=true
MARP_LLM_PROVIDER=none
MARP_LLM_MODEL=
MARP_LLM_API_KEY=
MARP_LLM_BASE_URL=
MARP_LLM_TIMEOUT_SECONDS=20
WEB_PORT=80
API_PORT=8000

BUILD_HTTP_PROXY=
BUILD_HTTPS_PROXY=
BUILD_NO_PROXY=localhost,127.0.0.1,host.docker.internal

POSTGRES_DB=marp
POSTGRES_USER=marp
POSTGRES_PASSWORD=marp
